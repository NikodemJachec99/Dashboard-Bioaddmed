COMPOSE_PROJECT_NAME=bioaddmed
APP_DOMAIN=bioaddmed.bieda.it
NGINX_HOST_PORT=8080

POSTGRES_DB=bioaddmed
POSTGRES_USER=bioaddmed
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://bioaddmed:change-me@postgres:5432/bioaddmed

DJANGO_SECRET_KEY=change-me
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=bioaddmed.bieda.it,localhost,127.0.0.1,backend
DJANGO_CORS_ALLOWED_ORIGINS=https://bioaddmed.bieda.it,http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=https://bioaddmed.bieda.it
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SUPERUSER_EMAIL=admin@bioaddmed.local
DJANGO_SUPERUSER_PASSWORD=change-me
DJANGO_SUPERUSER_FIRST_NAME=Admin
DJANGO_SUPERUSER_LAST_NAME=BioAddMed
DJANGO_LOGIN_THROTTLE=10/hour
DJANGO_PASSWORD_RESET_THROTTLE=5/hour

JWT_SIGNING_KEY=change-me
AUTH_COOKIE_DOMAIN=bioaddmed.bieda.it
AUTH_COOKIE_SECURE=True
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_PATH=/
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

VITE_API_URL=/api
